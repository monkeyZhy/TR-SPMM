ninja_required_version = 1.3
cxx = /home/zhaohongyang/miniconda3/envs/libra/bin/x86_64-conda-linux-gnu-c++
nvcc = /home/zhaohongyang/cuda-12.1/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/zhaohongyang/miniconda3/envs/libra/include -I/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/include -L/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/lib -L/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/lib/stubs -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/zhaohongyang/miniconda3/envs/libra/include -I/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/include -L/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/lib -L/home/zhaohongyang/miniconda3/envs/libra/targets/x86_64-linux/lib/stubs -fPIC -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/TH -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/THC -I/home/zhaohongyang/cuda-12.1/include -I/home/zhaohongyang/miniconda3/envs/libra/include/python3.9 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=Libra6SpMMOnline -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/TH -I/home/zhaohongyang/miniconda3/envs/libra/lib/python3.9/site-packages/torch/include/THC -I/home/zhaohongyang/cuda-12.1/include -I/home/zhaohongyang/miniconda3/envs/libra/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=Libra6SpMMOnline -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=sm_86 -ccbin /home/zhaohongyang/miniconda3/envs/libra/bin/x86_64-conda-linux-gnu-cc -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/zhaohongyang/TR-SPMM/TR-source/SpMM/build/temp.linux-x86_64-cpython-39/mGCN_online.o: compile /home/zhaohongyang/TR-SPMM/TR-source/SpMM/mGCN_online.cpp
build /home/zhaohongyang/TR-SPMM/TR-source/SpMM/build/temp.linux-x86_64-cpython-39/mGCNkernel_online.o: cuda_compile /home/zhaohongyang/TR-SPMM/TR-source/SpMM/mGCNkernel_online.cu






